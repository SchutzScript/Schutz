---
// 브라우저에서 웹뷰 + 에디터 효과를 실제 모습으로 확인하기 위한 개발용 하네스.
// 각 iframe에 확장이 보낼 법한 샘플 이벤트를 postMessage로 주입하고,
// "② 에디터" 패널은 실제 VSCode 데코레이션 효과(타이핑·글로우·인라인 수정됨 라벨)를
// 웹으로 재현한 데모다. (VSCode 확장과는 무관 — 순수 미리보기용)
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Schutz Webview Preview</title>
    <style is:global>
      body {
        margin: 0;
        background: #1e1e1e;
        color: #ccc;
        font-family: -apple-system, "Segoe UI", system-ui, sans-serif;
      }
      header {
        padding: 12px 16px;
        border-bottom: 1px solid #333;
        font-size: 14px;
        font-weight: 600;
      }
      header span { opacity: 0.55; font-weight: 400; }
      .grid {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 14px;
        padding: 16px;
        align-items: start;
      }
      .cell {
        border: 1px solid #333;
        border-radius: 10px;
        overflow: hidden;
        background: #1e1e1e;
      }
      .cell h2 {
        margin: 0;
        padding: 8px 12px;
        font-size: 11px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        opacity: 0.6;
        border-bottom: 1px solid #2b2b2b;
      }
      iframe { width: 100%; border: 0; display: block; background: #1e1e1e; }
      .chat iframe { height: 440px; }
      .activity iframe { height: 400px; }
      .overview iframe { height: 400px; }
      @media (max-width: 1100px) {
        .grid { grid-template-columns: 1fr; }
      }

      /* ── 미니 에디터 데모 ─────────────────────────── */
      .ed {
        font-family: Consolas, "Cascadia Code", "D2Coding", monospace;
        font-size: 13px;
        line-height: 1.65;
        padding: 10px 0;
        height: 440px;
        overflow: auto;
      }
      .ln { display: flex; white-space: pre; align-items: baseline; }
      .ln .no {
        width: 42px;
        text-align: right;
        padding-right: 16px;
        opacity: 0.32;
        user-select: none;
        flex: 0 0 auto;
        font-size: 12px;
      }
      .ln .tx { color: #d4d4d4; }
      .kw { color: #569cd6; }
      .str { color: #ce9178; }

      /* AI가 삽입한 라인 (pending) */
      .ln.ins {
        background: rgba(63, 185, 80, 0.12);
        box-shadow: inset 2.5px 0 0 rgba(63, 185, 80, 0.85);
      }
      .ln.ins .tx { color: #6a9955; }

      /* 방금 편집됨 — 파란 글로우가 초록 pending으로 사그라듦 */
      .ln.flash { animation: lineflash 1.3s ease; }
      @keyframes lineflash {
        0% { background: rgba(88, 166, 255, 0.38); }
        100% { background: rgba(63, 185, 80, 0.12); }
      }

      /* 타이핑 커서 */
      .typing::after {
        content: "▏";
        color: #58a6ff;
        font-weight: bold;
        animation: blink 0.9s steps(2) infinite;
      }
      @keyframes blink { 50% { opacity: 0; } }

      /* 코드 옆 인라인 "수정됨" 라벨 — 떠올랐다가 자연스럽게 사그라듦 */
      .edit-tag {
        margin-left: 22px;
        font-style: italic;
        font-size: 11.5px;
        color: rgba(88, 166, 255, 0.95);
        opacity: 0;
        transform: translateX(-6px);
        transition: opacity 0.45s ease, transform 0.45s ease;
        text-shadow: 0 0 10px rgba(88, 166, 255, 0.4);
      }
      .edit-tag.show { opacity: 1; transform: none; }
      .edit-tag.fade { opacity: 0; transition: opacity 1.6s ease; }
    </style>
  </head>
  <body>
    <header>Schutz 웹뷰 미리보기 <span>— 확장 없이 브라우저에서 보는 개발용 하네스</span></header>
    <div class="grid">
      <div class="cell editor">
        <h2>② 에디터 — 코드 안 인라인 수정 표시</h2>
        <div id="editor" class="ed"></div>
      </div>
      <div class="cell chat">
        <h2>① 채팅</h2>
        <iframe id="chat" src="/chat"></iframe>
      </div>
      <div class="cell activity">
        <h2>③ Agent 활동</h2>
        <iframe id="activity" src="/activity"></iframe>
      </div>
      <div class="cell overview">
        <h2>④ 멀티파일 오버뷰</h2>
        <iframe id="overview" src="/overview"></iframe>
      </div>
    </div>

    <script>
      // ══════════ 에디터 데모: 타이핑 → 글로우 → 인라인 "수정됨" 라벨 ══════════
      const ed = document.getElementById("editor");
      const wait = (ms) => new Promise((r) => setTimeout(r, ms));

      const baseLines = [
        "interface User {",
        "  id: string;",
        "  name: string;",
        "}",
        "",
        "function greet(user: User): string {",
        "  return `안녕하세요, ${user.name}님!`;",
        "}",
        "",
        "const alice: User = { id: \"u1\", name: \"Alice\" };",
        "console.log(greet(alice));",
      ];
      const banner = [
        "// ─────────────────────────────────────",
        "// Reviewed by Schutz — 자동 문서 배너",
        "// ─────────────────────────────────────",
      ];

      function makeLine(text, cls) {
        const ln = document.createElement("div");
        ln.className = "ln" + (cls ? " " + cls : "");
        const no = document.createElement("span");
        no.className = "no";
        const tx = document.createElement("span");
        tx.className = "tx";
        tx.textContent = text;
        ln.appendChild(no);
        ln.appendChild(tx);
        return ln;
      }

      function renumber() {
        let i = 1;
        for (const ln of ed.querySelectorAll(".ln")) {
          ln.querySelector(".no").textContent = i++;
        }
      }

      function renderBase() {
        ed.innerHTML = "";
        for (const t of baseLines) ed.appendChild(makeLine(t));
        renumber();
      }

      async function editorDemo() {
        renderBase();
        await wait(1400);

        // 1) AI가 상단에 배너를 "타이핑"으로 삽입
        const inserted = [];
        for (let li = 0; li < banner.length; li++) {
          const ln = makeLine("", "ins");
          const tx = ln.querySelector(".tx");
          tx.classList.add("typing");
          ed.insertBefore(ln, ed.children[li]);
          renumber();
          for (const ch of banner[li]) {
            tx.textContent += ch;
            await wait(11);
          }
          tx.classList.remove("typing");
          inserted.push(ln);
        }

        // 2) 파란 글로우 → pending 초록으로 사그라듦
        for (const ln of inserted) ln.classList.add("flash");

        // 3) 코드 옆 인라인 라벨: "✦ 수정됨 · 문서화 개선" 떠오름
        const tag = document.createElement("span");
        tag.className = "edit-tag";
        tag.textContent = "✦ 수정됨 · 문서화 개선";
        inserted[1].appendChild(tag);
        requestAnimationFrame(() => tag.classList.add("show"));

        // 4) 잠시 보여준 뒤 자연스럽게 페이드아웃 (pending 초록 표시는 유지)
        await wait(2800);
        tag.classList.remove("show");
        tag.classList.add("fade");
        await wait(1700);
        tag.remove();

        // 5) 잠시 뒤 데모 반복
        await wait(2600);
        editorDemo();
      }

      // ══════════ 웹뷰 iframe 샘플 데이터 주입 ══════════
      function send(id, msg) {
        const f = document.getElementById(id);
        if (f && f.contentWindow) f.contentWindow.postMessage(msg, "*");
      }

      function feedChat() {
        send("chat", { type: "status", text: "Mock 생각 중…" });
        send("chat", { type: "turn_start" });
        const full =
          "examples/demo.ts (14줄)를 살펴봤어요. 파일 상단 문서 배너를 추가하고, " +
          "첫 번째 함수 위에 설명 주석을 붙이겠습니다. 모든 변경은 수락/거절하실 수 있어요.";
        let i = 0;
        const timer = setInterval(() => {
          i += 4;
          send("chat", { type: "assistant_text", full: full.slice(0, i) });
          if (i >= full.length) {
            clearInterval(timer);
            send("chat", { type: "turn_end" });
            send("chat", { type: "status", text: "대기 중" });
          }
        }, 40);
      }

      function feedActivity() {
        send("activity", { type: "turn_start" });
        send("activity", {
          type: "plan",
          steps: [
            { id: "s1", title: "활성 파일 읽기", status: "done" },
            { id: "s2", title: "개선점 분석", status: "done" },
            { id: "s3", title: "편집 적용", status: "active" },
          ],
        });
        send("activity", { type: "tool", phase: "call", id: "t1", name: "read_file" });
        setTimeout(
          () => send("activity", { type: "tool", phase: "result", id: "t1", name: "read_file" }),
          600,
        );
        send("activity", { type: "usage", inputTokens: 1240, outputTokens: 180 });
      }

      function feedOverview() {
        send("overview", {
          type: "render",
          cards: [
            { file: "examples/demo.ts", added: 4, removed: 0, status: "pending", txId: "tx-1" },
            { file: "examples/user.ts", added: 1, removed: 0, status: "pending", txId: "tx-2" },
            { file: "examples/greet.ts", added: 1, removed: 0, status: "pending", txId: "tx-3" },
          ],
        });
      }

      window.addEventListener("load", () => {
        editorDemo();
        setTimeout(() => {
          feedChat();
          feedActivity();
          feedOverview();
        }, 500);
      });
    </script>
  </body>
</html>
