---
import View from "../layouts/View.astro";
---

<View title="Schutz Chat">
  <div id="messages"></div>
  <div id="composer">
    <div class="box">
      <textarea id="input" rows="1" placeholder="무엇이든 요청하세요…"></textarea>
      <div class="row">
        <span id="status" class="status">대기 중</span>
        <div class="spacer"></div>
        <button id="cancel" class="btn ghost" hidden>중지</button>
        <button id="send" class="send" title="전송 (Enter)" disabled>
          <svg width="14" height="14" viewBox="0 0 16 16" fill="none">
            <path d="M8 13V3M8 3L3.5 7.5M8 3l4.5 4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    </div>
    <div class="hint">Enter 전송 · Shift+Enter 줄바꿈</div>
  </div>
</View>

<style is:global>
  html, body { height: 100%; }
  body { display: flex; flex-direction: column; }

  /* ── 메시지 ─────────────────────────────────────── */
  #messages {
    flex: 1;
    overflow-y: auto;
    padding: 12px 10px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .msg {
    padding: 8px 11px;
    border-radius: 10px;
    white-space: pre-wrap;
    word-break: break-word;
    line-height: 1.55;
    animation: msg-in 0.22s ease;
  }
  @keyframes msg-in {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: none; }
  }
  .msg.user {
    align-self: flex-end;
    max-width: 85%;
    background: var(--vscode-button-background);
    color: var(--vscode-button-foreground);
    border-bottom-right-radius: 4px;
  }
  .msg.assistant {
    align-self: flex-start;
    max-width: 92%;
    background: var(--vscode-editorWidget-background, rgba(128, 128, 128, 0.12));
    border: 1px solid var(--vscode-editorWidget-border, rgba(128, 128, 128, 0.2));
    border-bottom-left-radius: 4px;
  }
  .msg.assistant.streaming::after {
    content: "▏";
    color: var(--schutz-accent);
    animation: blink 1s steps(2) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  /* ── 컴포저 ─────────────────────────────────────── */
  #composer { padding: 8px 10px 6px; }
  #composer .box {
    background: var(--vscode-input-background);
    border: 1px solid var(--vscode-input-border, rgba(128, 128, 128, 0.35));
    border-radius: 12px;
    padding: 8px 10px 6px;
    transition: border-color 0.18s ease, box-shadow 0.18s ease;
  }
  #composer .box:focus-within {
    border-color: var(--schutz-accent);
    box-shadow: 0 0 0 1px rgba(88, 166, 255, 0.35), 0 0 14px rgba(88, 166, 255, 0.12);
  }
  #input {
    width: 100%;
    max-height: 120px;
    resize: none;
    background: transparent;
    color: var(--vscode-input-foreground);
    border: none;
    outline: none;
    padding: 2px 2px 6px;
    font-family: inherit;
    font-size: 13px;
    line-height: 1.5;
  }
  #composer .row { display: flex; align-items: center; gap: 6px; }
  .status { font-size: 11px; opacity: 0.6; transition: opacity 0.2s; }
  .status.busy { opacity: 0.95; color: var(--schutz-accent); }

  .send {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: var(--vscode-button-background);
    color: var(--vscode-button-foreground);
    transition: transform 0.12s ease, opacity 0.15s ease, background 0.15s ease;
  }
  .send:hover:not(:disabled) { background: var(--vscode-button-hoverBackground); transform: scale(1.08); }
  .send:active:not(:disabled) { transform: scale(0.95); }
  .send:disabled { opacity: 0.35; cursor: default; }

  .hint {
    font-size: 10px;
    opacity: 0.4;
    text-align: right;
    padding: 4px 4px 0;
  }
</style>

<script>
  const vscode =
    typeof acquireVsCodeApi !== "undefined"
      ? acquireVsCodeApi()
      : { postMessage: () => {} };
  const messages = document.getElementById("messages");
  const input = document.getElementById("input");
  const send = document.getElementById("send");
  const cancel = document.getElementById("cancel");
  const status = document.getElementById("status");

  let streamingEl = null;

  // ── 메시지 ───────────────────────────────────────
  function addMessage(role, text) {
    const el = document.createElement("div");
    el.className = "msg " + role;
    el.textContent = text;
    messages.appendChild(el);
    messages.scrollTop = messages.scrollHeight;
    return el;
  }

  function autoResize() {
    input.style.height = "auto";
    input.style.height = Math.min(input.scrollHeight, 120) + "px";
    send.disabled = input.value.trim().length === 0;
  }

  function submit() {
    const text = input.value.trim();
    if (!text || send.disabled === "busy") return;
    addMessage("user", text);
    input.value = "";
    autoResize();
    streamingEl = addMessage("assistant", "");
    streamingEl.classList.add("streaming");
    vscode.postMessage({ type: "submit", text });
  }

  send.addEventListener("click", submit);
  cancel.addEventListener("click", () => vscode.postMessage({ type: "cancel" }));
  input.addEventListener("input", autoResize);
  input.addEventListener("keydown", (e) => {
    if (e.key === "Enter" && !e.shiftKey) {
      e.preventDefault();
      submit();
    }
  });
  autoResize();

  window.addEventListener("message", (event) => {
    const m = event.data;
    switch (m.type) {
      case "assistant_text":
        if (!streamingEl) {
          streamingEl = addMessage("assistant", "");
          streamingEl.classList.add("streaming");
        }
        streamingEl.textContent = m.full;
        messages.scrollTop = messages.scrollHeight;
        break;
      case "status":
        status.textContent = m.text;
        break;
      case "turn_start":
        cancel.hidden = false;
        status.classList.add("busy");
        break;
      case "turn_end":
        cancel.hidden = true;
        status.classList.remove("busy");
        if (streamingEl) streamingEl.classList.remove("streaming");
        streamingEl = null;
        break;
      case "error":
        addMessage("assistant", "⚠️ " + m.message);
        break;
    }
  });
</script>
