{
  // 느슨한 저장소 안의 엄격한 섬.
  // 루트는 "strict": false 라 undefined 가 조용히 흐른다. 엔진은 전부 신규 코드라
  // 엄격하게 시작하는 비용이 0 이고, 이 모듈이 막으려는 바로 그 버그 부류
  // (누락된 실행 레코드, undefined 위임)를 컴파일 타임에 잡는다.
  //
  // 루트 tsconfig 는 테스트를 제외하지만(빌드가 깨지므로) 여기서는 포함해서
  // 테스트 코드도 같은 엄격도로 검사한다.
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    // 엔진은 import 가 0 이라 @types/react 등이 필요 없다. vitest 만 있으면 된다.
    // 루트에 "types" 를 넣으면 @types/react 가 배제돼 앱 전체가 깨지지만, 여기서는 안전하다.
    "types": ["node"]
  },
  "include": ["**/*.ts"],
  "exclude": []
}
